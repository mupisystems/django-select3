include README.md
include LICENSE
include pyproject.toml
include *.py
recursive-include templates *
recursive-include static *

global-exclude __pycache__
global-exclude *.py[cod]

prune venv
prune .venv
prune __pycache__
prune .pytest_cache
prune assets
prune .git
prune .github
prune .vscode
prune .idea
